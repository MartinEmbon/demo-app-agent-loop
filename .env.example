# Copy this file to `.env` and fill in real values.
# Never commit `.env` — it's in .gitignore.

# AgentLoop API key for the demo org.
# Get this from your AgentLoop dashboard → /keys page.
# Format: ak_live_...
AGENTLOOP_API_KEY=ak_live_replace_me

# Where AgentLoop's backend lives. Leave as-is for production.
# For local backend testing, set to: http://localhost:8080
AGENTLOOP_BASE_URL=https://api.getagentloop.io

# OpenAI API key. Used by both tabs (chat via LangChain, triage via direct OpenAI wrapper).
OPENAI_API_KEY=sk-replace_me

# Which OpenAI model to use. gpt-4o-mini is fast + cheap and good enough for the demo.
# Stronger models are less likely to give cleanly-wrong answers, which makes the demo
# less compelling — so cheaper actually works in our favor here.
OPENAI_MODEL=gpt-4o-mini
